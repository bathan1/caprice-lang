(* TEST
  include splayable;
*)


let pos_int = { i : int | i > 0 }

let factors (dep n : pos_int) : list { m : pos_int | n % m == 0 } =
  let rec factors (dependent i : pos_int) : list { k : int | k >= i && n % k == 0 } =
    if i > n then
      []
    else if n % i == 0 then
      i :: factors (i + 1)
    else
      factors (i + 1)
  in
  factors 1
