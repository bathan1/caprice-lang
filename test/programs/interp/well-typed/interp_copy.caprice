(* TEST
  typing = no-error;
  flags = " -t 10.0";
  speed = slow;
  typecheck;
*)

(*
  T n is a module with a type with n parameters, e.g.

    T 2 is
      sig val t : type -> type -> type end

    T 0 is
      sig val t : type end
*)
let T n = sig
  val t :
    let rec loop i =
      if i <= 0
      then type
      else type -> loop (i - 1)
    in
    loop n
end

let Type : sig
  val t : type
  val type_int : t
  val eq : t -> t -> bool
  val is_int : t -> bool
end = struct
  let t = mu t.
    | `TArrow of t * t
    | `TInt of unit

  let type_int = `TInt ()

  let rec eq a b =
    match a, b with
    | `TArrow (t1, t2), `TArrow (t1', t2') ->
      eq t1 t1'
      && eq t2 t2'
    | `TInt _, `TInt _ ->
      true
    | _ ->
      false
    end

  let is_int = eq type_int
end

let Ident : sig
  val t : type
  val eq : t -> t -> bool
end = struct
  let t = `Id of int
  let eq a b =
    match a, b with
    | `Id x, `Id y -> x == y
    end
end

let Expr : T 0 = struct
  let t = mu t.
    | `Int of int
    | `Var of Ident.t
    | `Function of sig
       val id : Ident.t
       val typ : Type.t
       val body : t
    end
    | `If_then_else of t * t * t
    | `Plus of t * t
    | `Minus of t * t
    | `Equal of t * t
    | `Appl of t * t
end

let rec mem ls a eq =
  match ls with
  | [] -> false
  | hd :: tl ->
    eq a hd || mem tl a eq
  end

let free_vars e bound =
  let rec loop e bound_ids acc =
    match e with
    | `Var var_id ->
      if mem bound_ids var_id Ident.eq
      then acc
      else var_id :: acc
    | `Int i -> acc
    | `Function f -> loop f.body (f.id :: bound_ids) acc
    | `If_then_else (cond, true_, false_) ->
      let acc1 = loop cond bound_ids acc in
      let acc2 = loop true_ bound_ids acc1 in
      loop false_ bound_ids acc2
    | `Plus (a, b)
    | `Minus (a, b)
    | `Equal (a, b)
    | `Appl (a, b) ->
      loop b bound_ids (loop a bound_ids acc)
    end
  in
  loop e bound []

let is_closed e bound =
  match free_vars e bound with
  | [] -> true
  | _ -> false
  end

let Value : T 0 = struct
  let t =
    `Int of int
    | `Function of sig
       val id : Ident.t
       val typ : Type.t
       val body : { e : Expr.t | is_closed e [ id ] }
    end
end

let Result = struct
  let t a =
    | `Ok of a
    | `Error of unit

  let bind x f =
    match x with
    | `Error _ -> x
    | `Ok a -> f a
    end

  let return a = `Ok a

  let error = `Error ()

  let is_ok x =
    match x with
    | `Ok _ -> true
    | _ -> false
    end
end

let typecheck e =
  let add_to_env gamma id tau =
    fun id_ ->
      if Ident.eq id_ id
      then Result.return tau
      else gamma id_
  in
  let rec typecheck e gamma =
    let tc e =
      typecheck e gamma
    in
    match e with
    (* Axioms *)
    | `Var id -> gamma id
    | `Int i -> Result.return Type.type_int
    (* Functions *)
    | `Function f ->
      Result.bind (typecheck f.body (add_to_env gamma f.id f.typ)) (fun tau ->
        Result.return (`TArrow (f.typ, tau))
      )
    | `Appl (func, arg) ->
      Result.bind (tc func) (fun res ->
        match res with
        | `TArrow (dom, cod) ->
          Result.bind (tc arg) (fun tau_arg ->
            if Type.eq dom tau_arg
            then Result.return cod
            else Result.error
          )
        | _ -> Result.error
        end
      )
    (* Conditions *)
    | `If_then_else (cond, true_, false_) ->
      Result.bind (tc cond) (fun tau_cond ->
        if Type.is_int tau_cond
        then
          Result.bind (tc true_) (fun tau_left ->
            Result.bind (tc false_) (fun tau_right ->
              if Type.eq tau_left tau_right
              then Result.return tau_left
              else Result.error
            )
          )
        else Result.error
      )
    (* Simple expressions *)
    | `Plus (a, b)
    | `Minus (a, b)
    | `Equal (a, b) ->
      Result.bind (tc a) (fun tau_left ->
        Result.bind (tc b) (fun tau_right ->
          if
            Type.is_int tau_left
            && Type.is_int tau_right
          then
            Result.return Type.type_int
          else
            Result.error
        )
      )
    end
  in
  (* default environment is empty, so it is error given any id *)
  typecheck e (fun _ -> Result.error)

(*
  Note that we don't actually have to check for closed because
  that would be an unbound variable when typechecking.
*)
let is_closed_and_well_typed e =
  Result.is_ok (typecheck e)

let subst e id v =
  let rec sub e =
    let sub_pair p =
      match p with
      | a, b -> sub a, sub b
      end
    in
    match e with
    | `Var var_id ->
        if Ident.eq var_id id
        then v
        else e
    | `Int i -> e
    | `Function f ->
        if Ident.eq f.id id
        then e
        else `Function struct
          let id = f.id
          let typ = f.typ
          let body = sub f.body
        end
    | `Plus p -> `Plus (sub_pair p)
    | `Minus p -> `Minus (sub_pair p)
    | `Equal p -> `Equal (sub_pair p)
    | `Appl p -> `Appl (sub_pair p)
    | `If_then_else (cond, true_, false_) ->
      `If_then_else (sub cond, sub true_, sub false_)
    end
  in
  sub e

let rec eval (e : Expr.t | is_closed_and_well_typed e) : Value.t =
  let op_ints p op =
    match p with
    | x, y ->
      match eval x, eval y with
      | `Int i1, `Int i2 -> `Int (op i1 i2)
      end
    end
  in
  match e with
  | `Int i -> e
  | `Function _ -> e
  | `Plus p -> op_ints p (fun a b -> a + b)
  | `Minus p -> op_ints p (fun a b -> a - b)
  | `Equal p -> op_ints p (fun a b -> if a == b then 1 else 0)
  | `Appl (func, arg) ->
    match eval func with
    | `Function f -> eval (subst f.body f.id (eval arg))
    end
  | `If_then_else (cond, true_, false_) ->
    match eval cond with
    | `Int i ->
      if i <> 0 (* non-zero int is true; like in C *)
      then eval true_
      else eval false_
    end
  end
