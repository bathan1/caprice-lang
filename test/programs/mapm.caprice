(* TEST
  include refutable;
*)

let MONAD = sig
  val m : type --> type
  val return : (type a) -> a -> m a
  val bind : (type a b) -> m a -> (a -> m b) -> m b
  (* val map : (type a b) -> (a -> b) -> m a -> m b
  val join : (type a) -> m (m a) -> m a *)
end

let rec mapM (dep M : MONAD) (type a b) (f : a -> b) (ls : list a) : M.m (list b) =
  match ls with
  | [] -> M.return (list b) []
  | x::xs ->
    (* ERROR: (f x) is not in the monad *)
    M.bind b (list b) (f x) (fun y ->
      M.bind (list b) (list b) (mapM M a b f xs) (fun ys ->
        M.return (list b) (y :: ys)
      )
    )
  end
