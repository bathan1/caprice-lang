(* TEST
  include splayable;
*)

(* Encode mutually recursive functions by nesting them *)
let rec even (dep n : int | n >= 0) : { b : bool | b == (n % 2 == 0) } =
  let rec odd (dep n : int | n >= 0) : { b : bool | b == (n % 2 == 1) } =
    if n == 0 then
      false
    else 
      even (n - 1)
  in
  if n == 0 then
    true
  else 
    odd (n - 1)
