(* TEST
  include refute;
*)

(*
  This test comes from
    Sound and Complete Concolic Testing for Higher-order Functions
  by
    Shu-Hung You, Robert Bruce Findler, and Christos Dimoulas
  Figure 1

  The idea is that the counterexample f needs to call its argument
  twice in order to reach the assertion. Since (int -> bool) functions
  only have two outcomes, when a third function is applied to f, a
  single call can only distinguish it from the first or second functions,
  not both.
*)

let equals a b = a == b

let call_twice (f : (int -> bool) -> int) : int =
  if f (equals 2) <> 12 then
    1
  else if f (equals 30) <> 5 then
    2
  else if f (equals 7) <> -2 then
    3
  else
    assert false (* ERROR: this is reachable *)
