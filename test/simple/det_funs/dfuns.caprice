(* TEST
  include exhaust;
*)

(* Various combinations and uses of higher order functions. *)

let _ : (int -> int) -> int -> int =
  fun f -> f

let _ : (int -> int -> int) -> int =
  fun f ->
    let _ = f 0 in
    0

let _ : (int -> int -> int) -> int =
  fun f ->
    f 0 0

let _ : (int -> int -> int) -> int -> int -> int =
  fun f a b ->
    f a b

let _ : (int -> bool -> int) -> int -> bool -> int =
  fun f -> f

let _ : ((int -> int) -> int) -> (int -> int) -> int =
  fun f g ->
    let _ = assert (f g == f g) in
    f g

let _ : ((int -> int) -> int) -> (int -> int) -> int =
  fun f -> f

let _ : ((int -> int) -> int) -> (int -> int) -> int =
  fun f g ->
    f g

let _ : ((int -> int) -> int) -> unit =
  fun f ->
    let a = fun x -> x + 1 in
    let b = fun x -> 1 + x in
    assert (f a == f b)
