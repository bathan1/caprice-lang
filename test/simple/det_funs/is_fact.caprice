(* TEST
  include exhaust;
*)

let rec fact n =
  if n == 0 then
    1
  else
    n * fact (n - 1)

let is_small_fact (f : { n : int | 0 <= n && n <= 5 } -> int) : bool =
  f 0 == 1
  && f 1 == 1
  && f 2 == 2
  && f 3 == 6
  && f 4 == 24
  && f 5 == 120
  && f 2 == 2 (* for good measure :) *)

let _ = assert (is_small_fact fact)
