(* TEST
  include diverges;
*)

(* infinite producer of ints, given an int *)
let t = mu t. int -> int * t

let f (g : t -> int) (x : t) (y : t) : unit =
  let _ = g x in
  let a = g y in
  let b = g y in
  assert (a == b)

let f' (g : t -> int) (x : t) (y : t) : unit =
  let a = g y in
  let _ = g x in
  let b = g y in
  assert (a == b)

let x =
  let rec x j i =
    i*j, x (j + 1)
  in
  x 0

let y =
  let rec y j i =
    i*j, y (j + 2)
  in
  y 0

let xy (g : t -> int) : unit =
  let _ = g x in
  let a = g y in
  let b = g y in
  assert (a == b)

let xy' (g : t -> int) : unit =
  let a = g y in
  let _ = g x in
  let b = g y in
  assert (a == b)
