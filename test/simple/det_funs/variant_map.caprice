(* TEST
  include exhaust;
*)

let t =
  | `A of unit
  | `B of unit
  | `C of unit
  | `D of unit

let a = fun x ->
  match x with
  | `A () -> 0
  | `B () -> 1
  | `C () -> 2
  | `D () -> 3
  end

let b = fun x ->
  match x with
  | `A () -> 1
  | `B () -> 1
  | `C () -> 2
  | `D () -> 3
  end

let c = fun x ->
  match x with
  | `A () -> 1
  | `B () -> 2
  | `C () -> 2
  | `D () -> 3
  end

let d = fun x ->
  match x with
  | `A () -> 0
  | `B () -> 1
  | `C () -> 2
  | `D () -> 3
  end

let f (g : (t -> int) -> int) : unit =
  let i = g a in
  let j = g b in
  let k = g c in
  let l = g d in
  assert (i == l)
