(* TEST
  include exhaust;
*)

(*
  Hack to avoid solver simplification. This forces x = c
  without propagating x=c through the formulas.

  This way, we must query the solver to see if any of the
  binary operations could go differently.
*)
let eq x c =
  c - 1 < x && x < c + 1

let assert_div a b c =
  let _ : (x : int | eq x a) -> { y : int | eq y b } -> unit =
    fun x y -> assert ((x / y) == c)
  in
  ()

let assert_mod a b c =
  let _ : (x : int | eq x a) -> { y : int | eq y b } -> unit =
    fun x y -> assert (x % y == c)
  in
  ()

(*
  Check concrete equalities.
  These formulas still go through the solver because of the symbolic
  `eq` and because the solver tries to fail the assertions.
*)
let _ = assert_div   5    3    1
let _ = assert_div (-5)   3  (-1)
let _ = assert_div   5  (-3) (-1)
let _ = assert_div (-5) (-3)   1

let _ = assert_mod   5    3    2
let _ = assert_mod (-5)   3  (-2)
let _ = assert_mod   5  (-3)   2
let _ = assert_mod (-5) (-3) (-2)

let _ = assert_div   6    3    2
let _ = assert_div (-6)   3  (-2)
let _ = assert_div   6  (-3) (-2)
let _ = assert_div (-6) (-3)   2

let _ = assert_mod   6    3  0
let _ = assert_mod (-6)   3  0
let _ = assert_mod   6  (-3) 0
let _ = assert_mod (-6) (-3) 0

(*
  Check invariants.
*)
let _ : (x : int | x < 0) -> { y : int | y > 0 && x % y <> 0 } -> unit =
  fun x y ->
    assert (x / y <= 0)

let _ : { x : int | x < 0 } -> unit =
  fun x ->
    assert (x / x == 1)

let _ : { x : int | x > 0 } -> unit =
  fun x ->
    assert (x / x == 1)

let _ : (x : int) -> { y : int | y <> 0 } -> unit =
  fun x y ->
    assert (x == (x / y) * y + (x % y))
