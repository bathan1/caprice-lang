(* TEST
  include exhaust;
*)

(* simplest possible *)

let t : singleton int = int

(* variants *)

let t : singleton (`A of int | `B of bool) =
  `A of int | `B of bool

(* polymorphism *)

let f (type a b) (dependent t : singleton a) (x : t) : a =
  x

(* sugar *)
let f (type a b) (dependent t := a) (x : t) : a =
  x

(* inside modules *)

let M : sig
  val t : singleton int
  val f : t -> t
end = struct
  let t = int
  let f = fun x -> x
end

let M : sig
  val t := int (* sugar for the above *)
  val f : t -> t
end = struct
  let t = int
  let f = fun x -> x
end
